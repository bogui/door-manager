# Copy this file to .env and fill in real values before running docker compose up.
# .env is gitignored — never commit it.

# GDS3710 entrance panel — admin password
# Used in: go2rtc (RTSP stream), asterisk/pjsip.conf (SIP auth), homeassistant/secrets.yaml (door open API)
PANEL_PASSWORD=changeme

# Camera RTSP passwords (username is admin on all cameras)
CAM1_PASSWORD=changeme
CAM2_PASSWORD=changeme

# Asterisk SIP test extension (9000) — dev only, remove before production
TEST_PASSWORD=changeme

# Asterisk Manager Interface password (used by Home Assistant)
AMI_PASSWORD=changeme
