# Copy this file to .env and fill in real values before running docker compose up.
# .env is gitignored — never commit it.

# ── Hosts (IP or hostname) ────────────────────────────────────────────────────
PANEL_HOST=192.168.1.20
CAM1_HOST=192.168.1.31
CAM2_HOST=192.168.1.32

# ── Usernames ─────────────────────────────────────────────────────────────────
PANEL_USER=admin
CAM_USER=admin

# ── Passwords ─────────────────────────────────────────────────────────────────

# GDS3710 entrance panel — admin password
# Used in: go2rtc (RTSP stream), asterisk/pjsip.conf (SIP auth), docker-compose (door-open URL)
PANEL_PASSWORD=changeme

# Camera RTSP passwords
CAM1_PASSWORD=changeme
CAM2_PASSWORD=changeme

# Asterisk SIP test extension (9000) — dev only, remove before production
TEST_PASSWORD=changeme

# Asterisk Manager Interface password (used by Home Assistant)
AMI_PASSWORD=changeme

# ── Home Assistant ────────────────────────────────────────────────────────────

# Mobile app notify target (find in HA: Developer Tools → Template → {{ services }} )
HA_NOTIFY_TARGET=notify.mobile_app_sm_a536b
